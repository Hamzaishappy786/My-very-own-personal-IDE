{
  "name": "@hamzaishappy786/hator",
  "productName": "Hator",
  "version": "0.1.4",
  "description": "A lightweight desktop code editor built with Electron and Monaco.",
  "author": "Hamzaishappy786",
  "license": "MIT",
  "homepage": "https://github.com/Hamzaishappy786/hator",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hamzaishappy786/hator.git",
    "directory": "."
  },
  "keywords": [
    "editor",
    "code-editor",
    "ide",
    "electron",
    "monaco",
    "terminal",
    "debugger"
  ],
  "main": "src/main/main.js",
  "bin": {
    "hator": "./bin/hator.js"
  },
  "files": [
    "bin/",
    "src/",
    "assets/"
  ],
  "scripts": {
    "build:css": "tailwindcss -i ./src/renderer/tailwind.css -o ./src/renderer/tailwind.build.css --minify",
    "prestart": "npm run build:css",
    "start": "electron .",
    "predist": "npm run build:css",
    "dist": "electron-builder",
    "test": "node --test \"test/**/*.test.js\""
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^31.0.0",
    "monaco-editor": "^0.50.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.2",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "build": {
    "appId": "com.hator.editor",
    "files": [
      "src/**/*",
      "node_modules/monaco-editor/min/**/*",
      "node_modules/@xterm/xterm/lib/**/*",
      "node_modules/@xterm/xterm/css/**/*",
      "node_modules/@xterm/addon-fit/lib/**/*",
      "node_modules/node-pty/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
